<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
      Intentionally NOT sandboxed: the app needs Accessibility (global
      push-to-talk key + synthesized paste) and to talk to a local Ollama
      server on localhost. Library validation is disabled so the ad-hoc
      signature can load WhisperKit's Core ML resources during development.
    -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <!-- Hardened Runtime: allow microphone capture (for notarized builds). -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
</dict>
</plist>
